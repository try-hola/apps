{
  "name": "postiz",
  "version": "1.0.3",
  "title": "Postiz",
  "description": "Open-source social media scheduling tool with AI features",
  "icon": "https://raw.githubusercontent.com/try-hola/apps/main/icons/postiz.svg",
  "ingress": {
    "service": "postiz",
    "port": 5000
  },
  "defaultEnv": [
    {
      "key": "JWT_SECRET",
      "value": "",
      "isSecret": true,
      "description": "Unique random string used to sign sessions. Generate one, e.g. `openssl rand -hex 32`."
    },
    {
      "key": "DISABLE_REGISTRATION",
      "value": "false",
      "isSecret": false,
      "description": "Leave 'false' when using Hola SSO — Postiz disables OIDC entirely when registration is off. Without SSO, set 'true' after creating your account to block further sign-ups."
    }
  ],
  "defaults": {
    "ports": [
      { "container": 5000, "protocol": "tcp" }
    ],
    "volumes": [
      { "containerPath": "/config" },
      { "containerPath": "/uploads" }
    ]
  },
  "auth": {
    "mode": "native-oidc",
    "oidc": {
      "redirectPath": "/settings",
      "scopes": ["openid", "profile", "email"],
      "env": {
        "issuer": "POSTIZ_OAUTH_URL",
        "clientId": "POSTIZ_OAUTH_CLIENT_ID",
        "clientSecret": "POSTIZ_OAUTH_CLIENT_SECRET",
        "authUrl": "POSTIZ_OAUTH_AUTH_URL",
        "tokenUrl": "POSTIZ_OAUTH_TOKEN_URL",
        "userinfoUrl": "POSTIZ_OAUTH_USERINFO_URL"
      },
      "staticEnv": {
        "POSTIZ_GENERIC_OAUTH": "true",
        "NEXT_PUBLIC_POSTIZ_OAUTH_DISPLAY_NAME": "Authentik"
      }
    }
  }
}
