{
  "name": "vaultwarden",
  "version": "1.3.1",
  "title": "Vaultwarden",
  "description": "Self-hosted, Bitwarden-compatible password manager",
  "icon": "https://raw.githubusercontent.com/try-hola/apps/main/icons/vaultwarden.svg",
  "ingress": {
    "service": "vaultwarden",
    "port": 80
  },
  "defaultEnv": [
    {
      "key": "DOMAIN",
      "value": "https://vaultwarden.example.com",
      "isSecret": false,
      "description": "Public URL — set to https://vaultwarden.<your HOLA_BASE_DOMAIN>/ (required for WebAuthn, attachments, email links)"
    },
    {
      "key": "SIGNUPS_ALLOWED",
      "value": "true",
      "isSecret": false,
      "description": "Allow new account registration. Set to false once your account exists."
    }
  ],
  "defaults": {
    "ports": [
      { "container": 80, "protocol": "tcp" }
    ],
    "volumes": [
      { "containerPath": "/data" }
    ]
  },
  "auth": {
    "mode": "none"
  }
}
