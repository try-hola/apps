{
  "name": "actual-budget",
  "version": "1.2.1",
  "title": "Actual Budget",
  "description": "Local-first personal finance and budgeting",
  "icon": "https://raw.githubusercontent.com/try-hola/apps/main/icons/actual-budget.svg",
  "ingress": {
    "service": "actual-budget",
    "port": 5006
  },
  "defaultEnv": [
    {
      "key": "ACTUAL_OPENID_SERVER_HOSTNAME",
      "value": "https://actual.example.com",
      "isSecret": false,
      "description": "Public URL — set to https://actual.<your HOLA_BASE_DOMAIN> (Actual builds its OIDC redirect from this)"
    }
  ],
  "defaults": {
    "ports": [
      { "container": 5006, "protocol": "tcp" }
    ],
    "volumes": [
      { "containerPath": "/data" }
    ]
  },
  "auth": {
    "mode": "native-oidc",
    "oidc": {
      "redirectPath": "/openid/callback",
      "scopes": ["openid", "profile", "email"],
      "env": {
        "issuer": "ACTUAL_OPENID_DISCOVERY_URL",
        "clientId": "ACTUAL_OPENID_CLIENT_ID",
        "clientSecret": "ACTUAL_OPENID_CLIENT_SECRET"
      }
    }
  }
}
