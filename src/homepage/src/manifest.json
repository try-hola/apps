{
  "name": "homepage",
  "version": "1.3.0",
  "title": "Homepage",
  "description": "A highly customizable application dashboard / start page",
  "icon": "https://raw.githubusercontent.com/try-hola/apps/main/icons/homepage.svg",
  "ingress": {
    "service": "homepage",
    "port": 3000
  },
  "consumes": "app-registry",
  "defaultEnv": [],
  "defaults": {
    "ports": [
      { "container": 3000, "protocol": "tcp" }
    ],
    "volumes": [
      { "containerPath": "/app/config" }
    ]
  },
  "auth": {
    "mode": "forward-auth"
  }
}
