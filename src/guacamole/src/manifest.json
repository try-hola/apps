{
  "name": "guacamole",
  "version": "2.0.0",
  "title": "Apache Guacamole",
  "description": "Clientless remote desktop gateway — RDP, VNC and SSH in your browser",
  "icon": "https://raw.githubusercontent.com/try-hola/apps/main/icons/guacamole.svg",
  "ingress": {
    "service": "guacamole",
    "port": 8080
  },
  "defaults": {
    "ports": [
      {
        "container": 8080,
        "protocol": "tcp"
      }
    ],
    "volumes": [
      {
        "containerPath": "/var/lib/postgresql/data"
      }
    ]
  },
  "auth": {
    "mode": "forward-auth"
  },
  "defaultEnv": [],
  "backup": {
    "preHook": {
      "service": "postgres",
      "command": ["sh", "-c", "pg_dump -U guacamole_user -d guacamole_db -f /backups/guacamole_db.sql"]
    },
    "postHook": {
      "service": "postgres",
      "command": ["sh", "-c", "rm -f /backups/guacamole_db.sql"]
    }
  },
  "upgrade": {
    "breaking": true,
    "preUpgradeBackup": "required",
    "upgradeNotesUrl": "https://github.com/pgautoupgrade/docker-pgautoupgrade"
  }
}
